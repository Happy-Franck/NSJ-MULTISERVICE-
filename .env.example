# ============================================================
# NSJ Multiservice — variables d'environnement
# Copiez ce fichier en .env.local puis renseignez vos valeurs.
# .env.local n'est PAS versionné (voir .gitignore).
# ============================================================

# --- Supabase ---
# Dashboard Supabase > Project Settings > Data API / API Keys
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre_anon_key
# ⚠️ SECRET — ne jamais exposer côté client
SUPABASE_SERVICE_ROLE_KEY=votre_service_role_key

# --- Email (SMTP / Nodemailer) ---

# OPTION A — DEV LOCAL avec un faux serveur SMTP (MailDev) : RECOMMANDÉ pour tester.
# Lancer dans un terminal :  npm run mail
# Interface web pour lire les mails capturés : http://localhost:1080
# (MailDev ne demande ni utilisateur ni mot de passe ; laisser SMTP_USER/PASS vides.)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=devis@nsj-multiservice.local

# OPTION B — PRODUCTION avec Gmail (décommenter et remplir, en commentant l'option A) :
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=votre_adresse@gmail.com
# SMTP_PASS=votre_mot_de_passe_application   # Gmail : "mot de passe d'application"
# SMTP_FROM=votre_adresse@gmail.com

# Adresse qui reçoit les demandes de devis
DEVIS_TO_EMAIL=solofonirina35@gmail.com
